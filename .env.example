DATABASE_URL=postgresql://app_user:<password>@192.168.1.211:5432/app_db
NODE_ENV=development

# Email OTP auth
OTP_SECRET=change-me-long-random-secret
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=otp@example.com
SMTP_PASS=change-me
OTP_FROM_EMAIL="WAYYAK <otp@example.com>"
# Non-production only: when SMTP is missing, log/return OTP for testing. Never enable in production.
ALLOW_DEV_OTP=true

# Static SFTP preview uses export. Backend deploy should set STATIC_EXPORT=false.
STATIC_EXPORT=true
